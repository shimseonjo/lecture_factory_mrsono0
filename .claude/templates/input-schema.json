{
  "$schema": "input_data.json 스키마 — input-agent가 생성하여 후속 Phase에 전달",
  "required": {
    "topic": {
      "type": "string",
      "description": "Q1: 강의 주제와 범위"
    },
    "target_learner": {
      "description": {
        "type": "string",
        "description": "Q2: 학습자 설명 (직무, 경력, 사전 지식)"
      },
      "level": {
        "type": "string",
        "enum": ["입문", "중급", "고급"],
        "description": "Q2: 학습자 수준"
      }
    },
    "learning_goals": {
      "type": "array",
      "items": "string",
      "description": "Q3: 측정 가능한 학습 목표 목록"
    },
    "format": {
      "type": {
        "type": "string",
        "enum": ["강의", "워크숍", "세미나"],
        "default": "강의",
        "description": "Q4: 진행 방식"
      },
      "mode": {
        "type": "string",
        "enum": ["오프라인", "온라인", "혼합"],
        "default": "오프라인",
        "description": "Q4: 공간"
      }
    },
    "schedule": {
      "preset": {
        "type": "string",
        "enum": ["단일 강의", "다회차 강의", "집중 워크숍"],
        "default": "집중 워크숍",
        "description": "Q5: 시간 프리셋"
      },
      "days": {
        "type": "number",
        "default": 5,
        "description": "Q5: 총 일수"
      },
      "hours_per_day": {
        "type": "number",
        "default": 8,
        "description": "Q5: 일일 교육 시간"
      },
      "session_minutes": {
        "type": "number",
        "default": 50,
        "description": "Q5: 1교시 시간 (분)"
      },
      "break_minutes": {
        "type": "number",
        "default": 10,
        "description": "Q5: 쉬는 시간 (분)"
      }
    },
    "keywords": {
      "type": "array",
      "items": "string",
      "description": "Q6: 반드시 포함할 주제/기술 키워드"
    }
  },
  "optional": {
    "prerequisites": {
      "type": "string|null",
      "default": null,
      "description": "Q7: 선수 지식 (null이면 초급부터)"
    },
    "exclusions": {
      "type": "string|null",
      "default": null,
      "description": "Q8: 제외 범위"
    },
    "assessment": {
      "type": "string",
      "default": "형성평가(퀴즈+실습)",
      "description": "Q9: 평가 방식"
    },
    "pedagogy": {
      "type": "string",
      "default": "PBL + AI-first, 실습 비율 50% 이상. 이론 후 즉시 실습 연결. 매일 산출물이 누적되는 프로젝트 기반 학습.",
      "description": "Q10a: 교수 전략"
    },
    "tone": {
      "type": "string",
      "default": "비유 중심 설명: IT 기반 지식이 있는 초보 강사가 자연스럽게 이해할 수 있도록 일상적 메타포 활용",
      "description": "Q10b: 톤·스타일"
    },
    "tone_examples": {
      "type": "array",
      "default": [
        "MCP = 'AI를 위한 범용 USB-C 케이블'",
        "서브에이전트 = '격리된 전문 AI 조수'",
        "CLAUDE.md = '프로젝트 신입사원 가이드북'",
        "Hooks = '사무실 출입 시스템'",
        "스킬 = '표준 작업 절차서(SOP)'",
        "렉처 팩토리 = 'AI 강의 제작 공장'",
        "역할 기반 에이전트 풀 = '건물 공용 서비스팀'"
      ],
      "description": "Q10b: 메타포 예시 목록"
    },
    "reference_sources": {
      "local_folders": {
        "type": "array",
        "items": "string",
        "default": [],
        "description": "Q11: 로컬 폴더 경로 목록 (Phase 2에서 분석)"
      },
      "notebooklm_urls": {
        "type": "array",
        "items": "string",
        "default": [],
        "description": "Q11: NotebookLM 공유 URL 목록 (Phase 2에서 NBLM 스킬로 분석)"
      }
    },
    "context": {
      "type": "string",
      "default": "독립 강의",
      "description": "Q12: 커리큘럼 맥락 (독립 강의 / 시리즈의 N번째 등)"
    }
  }
}
